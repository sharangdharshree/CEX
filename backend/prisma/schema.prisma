datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

model Users {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  firstName String
  lastName  String
  password  String

  sessions Sessions[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([username])
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model Sessions {
  id       String   @id @default(uuid())
  userId   String   
  user     Users    @relation(fields: [userId], references: [id])
  username String

  // Security tokens
  refreshToken     String       
  status           SessionStatus @default(ACTIVE)
  // authMethod       String        // e.g., "PASSWORD", "GOOGLE_SSO", "PASSKEY"
  
  // Geolocation & Device Metadata
  // ipAddress        String?
  // country          String?       // Parsed from IP on login
  // city             String?       // Parsed from IP on login
  // userAgent        String?       // Raw browser string
  // deviceName       String?       // User-customized label (Optional)
  
  // Fine-grained tracking timers
  revokedAt        DateTime?       
  expiresAt        DateTime      // Hard cutoff date/time
  // lastUsedAt       DateTime      @default(now()) // Updated on every API interaction
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId])
  @@index([username])
}

model Stocks {
  id     String @id @default(uuid())
  name   String
  symbol String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([symbol])
}

model Orders {
  id        String   @id @default(uuid())
  userId    String
  stockId   String
  quantity  Int
  price     Float
  type      String
  side      String
  filledQuantity Int
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Fills {
  id        String   @id @default(uuid())
  orderId   String
  stockId   String
  quantity  Int
  price     Float
  type      String
  side      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Balances {
  id        String   @id @default(uuid())
  userId    String
  stockId   String
  quantity  Int
  lockedQuantity Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

